# Postgres — used by Drizzle for migrations (superuser) and the app (least-privileged role)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/exec_db
DATABASE_URL_APP=postgres://app_runtime:CHANGE_ME@localhost:5432/exec_db

# Auth — set AUTH_PROVIDER=stub for local dev (no Clerk keys required).
#        Set AUTH_PROVIDER=clerk (the default) for staging and production.
AUTH_PROVIDER=stub

# Clerk — required when AUTH_PROVIDER=clerk (staging / production).
# Create a Clerk app at https://clerk.com and copy the keys from the API Keys page.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Anthropic — used by the vision-check CLI (and later autodraft / digest workers)
ANTHROPIC_API_KEY=

# Public
NEXT_PUBLIC_APP_NAME=exec-db
NODE_ENV=development
