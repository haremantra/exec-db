# Postgres — used by Drizzle for migrations (superuser) and the app (least-privileged role)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/exec_db
DATABASE_URL_APP=postgres://app_runtime:CHANGE_ME@localhost:5432/exec_db

# Auth — stub in Phase 0; swap to WorkOS or Clerk creds in Phase 1
AUTH_PROVIDER=stub
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
CLERK_SECRET_KEY=

# Anthropic — used by the vision-check CLI (and later autodraft / digest workers)
ANTHROPIC_API_KEY=

# Public
NEXT_PUBLIC_APP_NAME=exec-db
NODE_ENV=development
